{
  "name": "dice-flip",
  "version": "0.6.0",
  "type": "module",
  "description": "Tactile dice-flip component library for React with multiplayer sync support — configurable DicePanel with CSS Modules",
  "keywords": [
    "dice",
    "react",
    "component",
    "game",
    "library",
    "multiplayer",
    "sync"
  ],
  "homepage": "https://github.com/joshnapoles/dice-flip",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/joshnapoles/dice-flip.git"
  },
  "license": "MIT",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./dist/index.css": "./dist/index.css"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:demo": "vite build --config vite.config.demo.ts",
    "lint": "eslint .",
    "preview": "vite preview",
    "prepublishOnly": "npm run build",
    "predeploy": "npm run build:demo",
    "deploy": "gh-pages -d dist-demo",
    "release": "bash release.sh"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "gh-pages": "^6.3.0",
    "globals": "^16.5.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.48.0",
    "vite": "^7.3.1",
    "vite-plugin-dts": "^4.5.4"
  }
}
